# API base used by the runtime (browser-side fetches). If this is an
# absolute URL, requests go directly to it. If it's a relative path like
# `/api/v1`, requests go through Vite's dev proxy → VITE_API_TARGET.
VITE_API_BASE_URL=https://api.satzone.dev/

# Dev-only: where Vite's devserver proxy forwards `/api` and `/media`
# requests. Leave blank if VITE_API_BASE_URL is already absolute. Set22 to
# a local backend for full local dev, e.g. http://localhost:8000.
VITE_API_TARGET=

# Telegram bot used by the phone-verification page. Full t.me URL.
VITE_TELEGRAM_BOT_URL=https://t.me/satzone_verification_test_bot

# ── Results CMS (server/) ────────────────────────────────────────────────
# Base URL the browser uses for the CMS API. Relative → proxied by Vite in
# dev (see vite.config.ts); same-origin in prod (Node serves SPA + API).
VITE_CMS_BASE_URL=/cms/api

# CMS Node server (server/index.js), consumed via `node --env-file=.env`.
# ADMIN_PASSWORD gates the private /admin/results panel.
# ADMIN_SESSION_SECRET signs admin session tokens — set a long random value.
CMS_PORT=8787
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
