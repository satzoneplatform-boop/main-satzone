# API base used by the runtime (browser-side fetches). If this is an
# absolute URL, requests go directly to it. If it's a relative path like
# `/api/v1`, requests go through Vite's dev proxy → VITE_API_TARGET.
VITE_API_BASE_URL=https://api.satzone.org/

# Dev-only: where Vite's devserver proxy forwards `/api` and `/media`
# requests. Leave blank if VITE_API_BASE_URL is already absolute. Set22 to
# a local backend for full local dev, e.g. http://localhost:8000.
VITE_API_TARGET=

# Telegram bot used by the phone-verification page. Full t.me URL.
VITE_TELEGRAM_BOT_URL=https://t.me/satzone_verification_bot
